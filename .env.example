# Root .env.example - copy to .env and fill in values
# Use these when running locally (yarn dev). Vercel uses Environment Variables in the dashboard.

# Optional: Postgres connection string for future DB features
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Client (Vite) - only used at build time for client
# Point to your deployed server API URL when building for production
VITE_API_URL=http://localhost:3001/api

# Server
PORT=3001
